rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Session materials: authenticated users can upload/read
    match /sessions/{bookingId}/materials/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Profile images (future use)
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
