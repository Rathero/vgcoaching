rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: solo pueden leer/escribir su propio perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // CRM Local (Nota: 'if true' permite acceso público. Considera añadir Auth en el futuro)
    match /crm_leads/{docId} {
      allow read, write: if true;
    }
    match /crm_settings/{docId} {
      allow read, write: if true;
    }

    // Public read collections (managed by admin SDK only)
    match /coaches/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /games/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /coachGames/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /coachingOptions/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /availability/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /reviews/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Bookings + subcollections (materials, messages)
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;

      // Session materials (uploaded files/notes)
      match /materials/{materialId} {
        allow read, write: if request.auth != null;
      }

      // Session chat messages
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
